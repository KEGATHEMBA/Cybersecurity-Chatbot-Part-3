<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity ChatBot"
        Height="600"
        Width="900"
        Background="Black">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">

            <TextBlock Text="CYBERSECURITY CHATBOT"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Lime"
                       Margin="0,0,0,10"/>

            <RichTextBox x:Name="rtbChat"
                         Height="400"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="rtbChat_TextChanged"/>

            <StackPanel Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal"></StackPanel>

                <TextBox x:Name="txtMessage"
                         Width="500"
                         Height="30"/>

                <Button x:Name="btnSend"
                        Content="Send"
                        Width="100"
                        Margin="10,0,0,0"
                        Click="BtnSend_Click"/>

                <TextBlock Text="Quiz Answer:" Margin="5"/>

                <TextBox x:Name="txtQuizAnswer"
                         Width="100"
                         Height="30"
                         Margin="5"
                         ToolTip="Enter answer number"/>

                <Button x:Name="btnSubmitAnswer"
                        Content="Submit Answer"
                        Width="120"
                        Height="30"
                        Margin="5"
                        Click="BtnSubmitAnswer_Click"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                    <Button x:Name="btnStartQuiz"
                        Content="Start Quiz"
                        Width="120"
                        Height="30"
                        Margin="5"
                        Click="BtnStartQuiz_Click"/>
                </StackPanel>

            </StackPanel>

        </StackPanel>

       
        <GroupBox Header="Task Assistant"
                  Grid.Column="1"
                  Margin="10">

            <StackPanel Margin="10">

                <TextBox x:Name="txtTaskTitle"
                         Margin="0,5"
                         Height="30"/>

                <TextBox x:Name="txtTaskDescription"
                         Margin="0,5"
                         Height="70"
                         AcceptsReturn="True"/>

                <DatePicker x:Name="dpReminder"
                            Margin="0,5"/>

                <Button x:Name="btnAddTask"
                        Content="Add Task"
                        Margin="0,5"
                        Click="BtnAddTask_Click"/>

                <Button x:Name="btnViewTasks"
                        Content="View Tasks"
                        Margin="0,5"
                        Click="BtnViewTasks_Click"/>

                <Button x:Name="btnCompleteTask"
                        Content="Complete Task"
                        Margin="0,5"
                        Click="BtnCompleteTask_Click"/>

                <Button x:Name="btnDeleteTask"
                        Content="Delete Task"
                        Margin="0,5"
                        Click="BtnDeleteTask_Click"/>

            </StackPanel>

        </GroupBox>

    </Grid>

</Window>
